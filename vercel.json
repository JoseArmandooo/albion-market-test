{
  "crons": [
    {
      "path": "/api/market/sync",
      "schedule": "*/1 * * * *"
    }
  ],
  "functions": {
    "src/app/api/market/sync/route.ts": {
      "maxDuration": 300
    }
  },
  "buildCommand": "prisma generate && prisma db push && next build",
  "env": {
    "ALBION_API_BASE_URL": "https://west.albion-online-data.com/api/v2"
  }
}
